// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  extensions = [uuid_ossp(map: "uuid-ossp"), postgis]
}

// =========================================================================
// CONFIGURACIÓN DE CONEXIÓN Y EXTENSIONES (Mapeado con Neon + PostGIS)
// =========================================================================

// =========================================================================
// 1. MÓDULO DE USUARIOS Y ROLES
// =========================================================================

model Rol {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  nombre         String    @unique @db.VarChar(50)
  descripcion    String?   @db.Text
  fechaCreacion  DateTime  @default(now()) @map("fecha_creacion") @db.Timestamptz
  usuarios       Usuario[]

  @@map("rol")
}

model Usuario {
  id              String                    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  rolId           String                    @map("rol_id") @db.Uuid
  nombreCompleto  String                    @map("nombre_completo") @db.VarChar(150)
  email           String                    @unique @db.VarChar(150)
  telefono        String?                   @db.VarChar(20)
  passwordHash    String                    @map("password_hash") @db.Text
  fotoPerfilUrl   String?                   @map("foto_perfil_url") @db.Text
  fechaRegistro   DateTime                  @default(now()) @map("fecha_registro") @db.Timestamptz
  
  rol             Rol                       @relation(fields: [rolId], references: [id])
  biohuertos      Biohuerto[]
  plantasUsuario  CatalogoPlantaUsuario[]

  @@map("usuario")
}

// =========================================================================
// 2. MÓDULO DE BIOHUERTOS Y PARCELAS (Jerarquía Macro -> Micro)
// =========================================================================

model Biohuerto {
  id                  String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  duenoId             String               @map("dueno_id") @db.Uuid
  nombreHuerto        String               @map("nombre_huerto") @db.VarChar(100)
  descripcion         String?              @db.Text
  direccionTexto      String               @map("direccion_texto") @db.Text
  ubicacionGeo        Unsupported("geometry(Point, 4326)") // Campo nativo de PostGIS para mapas interactivos
  areaMetrosCuadrados Decimal              @map("area_metros_cuadrados") @db.Decimal(8, 2)
  fotoPortadaUrl      String?              @map("foto_portada_url") @db.Text
  fechaCreacion       DateTime             @default(now()) @map("fecha_creacion") @db.Timestamptz
  
  dueno               Usuario              @relation(fields: [duenoId], references: [id], onDelete: Cascade)
  parcelas            Parcela[]
  alertas             AlertaRecordatorio[]
  finanzas            RegistroFinanciero[]

  @@map("biohuerto")
}

model Parcela {
  id                  String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  biohuertoId         String    @map("biohuerto_id") @db.Uuid
  nombreIdentificador String    @map("nombre_identificador") @db.VarChar(100)
  areaMetrosCuadrados Decimal   @map("area_metros_cuadrados") @db.Decimal(8, 2)
  tipoSuelo           String?   @map("tipo_suelo") @db.VarChar(50)
  fechaCreacion       DateTime  @default(now()) @map("fecha_creacion") @db.Timestamptz
  
  biohuerto           Biohuerto @relation(fields: [biohuertoId], references: [id], onDelete: Cascade)
  cultivos            Cultivo[]

  @@map("parcela")
}

// =========================================================================
// 3. MÓDULO DE CATÁLOGOS Y PLANTAS
// =========================================================================

model CatalogoPlantaMaestro {
  id                          String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  nombreComun                 String                  @unique @map("nombre_comun") @db.VarChar(100)
  nombreCientifico            String?                 @map("nombre_cientifico") @db.VarChar(150)
  familiaBotanica             String                  @map("familia_botanica") @db.VarChar(100)
  tiempoEstimadoCosechaDias   Int                     @map("tiempo_estimado_cosecha_dias")
  iconoUrl                    String?                 @map("icono_url") @db.Text
  plantasUsuario              CatalogoPlantaUsuario[]

  @@map("catalogo_planta_maestro")
}

model CatalogoPlantaUsuario {
  id                             String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  usuarioId                      String                 @map("usuario_id") @db.Uuid
  plantaMaestraId                String?                @map("planta_maestra_id") @db.Uuid
  nombrePersonalizado            String?                @map("nombre_personalizado") @db.VarChar(100)
  familiaPersonalizada           String?                @map("familia_personalizada") @db.VarChar(100)
  tiempoCosechaPersonalizadoDias Int?                   @map("tiempo_cosecha_personalizado_dias")
  fechaAgregado                  DateTime               @default(now()) @map("fecha_agregado") @db.Timestamptz
  
  usuario                        Usuario                @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  plantaMaestra                  CatalogoPlantaMaestro? @relation(fields: [plantaMaestraId], references: [id], onDelete: SetNull)
  cultivos                       Cultivo[]

  @@map("catalogo_planta_usuario")
}

// =========================================================================
// 4. MÓDULO DE GESTIÓN DE CULTIVOS Y MONITOREO
// =========================================================================

model Cultivo {
  id                    String                    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  parcelaId             String                    @map("parcela_id") @db.Uuid
  plantaUsuarioId       String                    @map("planta_usuario_id") @db.Uuid
  fechaSiembra          DateTime                  @map("fecha_siembra") @db.Date
  etapaActual           String                    @default("Siembra") @map("etapa_actual") @db.VarChar(50)
  cantidadSembrada      String                    @map("cantidad_sembrada") @db.VarChar(100)
  metodoSiembra         String?                   @default("Al voleo") @map("metodo_siembra") @db.VarChar(50)
  fechaEstimadaCosecha  DateTime?                 @map("fecha_estimada_cosecha") @db.Date
  fechaCreacion         DateTime                  @default(now()) @map("fecha_creacion") @db.Timestamptz
  
  parcela               Parcela                   @relation(fields: [parcelaId], references: [id], onDelete: Cascade)
  plantaUsuario         CatalogoPlantaUsuario     @relation(fields: [plantaUsuarioId], references: [id])
  monitoreos            MonitoreoCultivo[]
  alertas               AlertaRecordatorio[]
  diagnosticos          DiagnosticoPlaga[]
  finanzas              RegistroFinanciero[]
  practicasAgricolas    RegistroPracticaAgricola[]
  publicaciones         PublicacionCosecha[]

  @@map("cultivo")
}

model MonitoreoCultivo {
  id                    String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  cultivoId             String   @map("cultivo_id") @db.Uuid
  fechaRegistro         DateTime @default(now()) @map("fecha_registro") @db.Timestamptz
  humedadSuelo          Decimal? @map("humedad_suelo") @db.Decimal(5, 2)
  temperaturaAmbiente   Decimal? @map("temperatura_ambiente") @db.Decimal(5, 2)
  luminosidadPorcentaje Decimal? @map("luminosidad_porcentaje") @db.Decimal(5, 2)
  incidenciasRelevantes String?  @map("incidencias_relevantes") @db.Text
  observaciones         String?  @db.Text
  
  cultivo               Cultivo  @relation(fields: [cultivoId], references: [id], onDelete: Cascade)

  @@map("monitoreo_cultivo")
}

model AlertaRecordatorio {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  biohuertoId     String    @map("biohuerto_id") @db.Uuid
  cultivoId       String?   @map("cultivo_id") @db.Uuid
  tipoAlerta      String    @default("Riego") @map("tipo_alerta") @db.VarChar(50)
  titulo          String    @db.VarChar(100)
  descripcion     String?   @db.Text
  prioridad       String    @default("MEDIA") @db.VarChar(20)
  fechaProgramada DateTime  @map("fecha_programada") @db.Timestamptz
  completada      Boolean   @default(false)
  fechaCompletada DateTime? @map("fecha_completada") @db.Timestamptz
  fechaCreacion   DateTime  @default(now()) @map("fecha_creacion") @db.Timestamptz
  
  biohuerto       Biohuerto @relation(fields: [biohuertoId], references: [id], onDelete: Cascade)
  cultivo         Cultivo?  @relation(fields: [cultivoId], references: [id], onDelete: SetNull)

  @@map("alerta_recordatorio")
}

// =========================================================================
// 5. MÓDULO DE DIAGNÓSTICO FITOSANITARIO (IA / SALUD)
// =========================================================================

model DiagnosticoPlaga {
  id                  String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  cultivoId           String   @map("cultivo_id") @db.Uuid
  fechaAnalisis       DateTime @default(now()) @map("fecha_analisis") @db.Timestamptz
  imagenUrl           String   @map("imagen_url") @db.Text
  resultadoDiagnostico String   @map("resultado_diagnostico") @db.VarChar(150)
  nivelConfianza      Decimal  @map("nivel_confianza") @db.Decimal(5, 2)
  tratamientoSugerido String   @map("tratamiento_sugerido") @db.Text
  
  cultivo             Cultivo  @relation(fields: [cultivoId], references: [id], onDelete: Cascade)

  @@map("diagnostico_plaga")
}

// =========================================================================
// 6. MÓDULO DE FINANZAS (COSTOS E INGRESOS)
// =========================================================================

model RegistroFinanciero {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  biohuertoId      String    @map("biohuerto_id") @db.Uuid
  cultivoId        String?   @map("cultivo_id") @db.Uuid
  tipoTransaccion  String    @map("tipo_transaccion") @db.VarChar(20) // 'INGRESO' o 'EGRESO'
  categoria        String    @db.VarChar(50)
  monto            Decimal   @db.Decimal(10, 2)
  descripcion      String?   @db.Text
  fechaTransaccion DateTime  @default(dbgenerated("CURRENT_DATE")) @map("fecha_transaccion") @db.Date
  
  biohuerto        Biohuerto @relation(fields: [biohuertoId], references: [id], onDelete: Cascade)
  cultivo          Cultivo?  @relation(fields: [cultivoId], references: [id], onDelete: SetNull)

  @@map("registro_financiero")
}

// =========================================================================
// 7. MÓDULO DE TRAZABILIDAD AGROECOLÓGICA
// =========================================================================

model RegistroPracticaAgricola {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  cultivoId       String   @map("cultivo_id") @db.Uuid
  tipoPractica    String   @map("tipo_practica") @db.VarChar(50)
  esOrganico      Boolean  @default(true) @map("es_organico")
  descripcion     String?  @db.Text
  fechaAplicacion DateTime @default(now()) @map("fecha_aplicacion") @db.Timestamptz
  
  cultivo         Cultivo  @relation(fields: [cultivoId], references: [id], onDelete: Cascade)

  @@map("registro_practica_agricola")
}

// =========================================================================
// 8. MÓDULO DE MARKETPLACE
// =========================================================================

model PublicacionCosecha {
  id                 String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  cultivoId          String   @map("cultivo_id") @db.Uuid
  titulo             String   @db.VarChar(150)
  descripcion        String?  @db.Text
  precioPorKg        Decimal  @map("precio_por_kg") @db.Decimal(10, 2)
  cantidadDisponible Decimal  @map("cantidad_disponible") @db.Decimal(10, 2)
  imagenUrl          String?  @map("imagen_url") @db.Text
  activa             Boolean  @default(true)
  fechaPublicacion   DateTime @default(now()) @map("fecha_publicacion") @db.Timestamptz
  
  cultivo            Cultivo  @relation(fields: [cultivoId], references: [id], onDelete: Cascade)

  @@map("publicacion_cosecha")
}